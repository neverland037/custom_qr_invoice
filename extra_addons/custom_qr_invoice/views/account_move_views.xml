<odoo>
    <record id="view_move_form_inherit_custom" model="ir.ui.view">
        <field name="name">account.move.form.inherit.custom</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="x_emission_date"/>
            </xpath>
            <xpath expr="//field[@name='invoice_user_id']" position="after">
                <field name="x_sale_channel_id" options="{'no_create': True}"/>
            </xpath>
            <xpath expr="//page[@name='other_info']" position="after">
                <page string="Transferencias (Stock)">
                    <field name="x_picking_ids" readonly="1"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>