<odoo>
    <template id="report_invoice_document_inherit" inherit_id="account.report_invoice_document">

        <xpath expr="//div[@id='informations']/div[@name='invoice_date']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>

        <xpath expr="//div[@id='informations']" position="inside">
            <div class="col-auto mw-100 mb-2" name="emission_date">
                <strong>Fecha de Emisión:</strong>
                <p class="m-0" t-field="o.x_emission_date"/>
            </div>
            <div class="col-auto mw-100 mb-2" t-if="o.x_sale_channel_id">
                <strong>Canal:</strong>
                <p class="m-0" t-field="o.x_sale_channel_id.name"/>
            </div>
            <div class="col-auto mw-100 mb-2">
                <strong>Serie:</strong>
                <p class="m-0" t-field="o.x_serie"/>
            </div>
            <div class="col-auto mw-100 mb-2">
                <strong>Correlativo:</strong>
                <p class="m-0" t-field="o.x_correlativo"/>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('page')]" position="inside">
            <div class="text-center mt-4" style="border-top: 1px solid #eee; padding-top: 20px;">
                <img t-if="o.x_qr_code" t-att-src="image_data_uri(o.x_qr_code)" style="max-height: 140px;"/>
                <p class="mt-2" style="font-size: 12px;">
                    <strong>Total Unidades: </strong>
                    <t t-esc="o.x_total_qty"/>
                </p>
            </div>
        </xpath>

    </template>
</odoo>