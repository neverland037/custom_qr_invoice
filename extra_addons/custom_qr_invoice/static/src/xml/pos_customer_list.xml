<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_qr_invoice.PartnerListScreen" t-inherit="point_of_sale.PartnerListScreen" t-inherit-mode="extension">
        <xpath expr="//table[hasclass('partner-list')]/thead/tr" position="inside">
            <th>Idioma</th>
        </xpath>
    </t>
    <t t-name="custom_qr_invoice.PartnerLine" t-inherit="point_of_sale.PartnerLine" t-inherit-mode="extension">
        <xpath expr="//tr" position="inside">
            <td><t t-esc="props.partner.lang or ''" /></td>
        </xpath>
    </t>
    <t t-name="custom_qr_invoice.PaymentScreen" t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('customer-button')]" position="after">
            <div class="button btn btn-primary py-3 w-100 mt-2" t-on-click="onClickBoleta">
                <i class="fa fa-ticket"></i> Boleta
            </div>
        </xpath>
    </t>
</templates>